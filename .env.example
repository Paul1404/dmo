# Postgres (provided by Railway when Postgres service is linked)
DATABASE_URL=postgres://user:password@localhost:5432/dmo

# Better-auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth app (https://github.com/settings/developers)
# Callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Port (auto-injected by Railway)
PORT=3000

# --- Abuse & cost protection (all optional, generous defaults) ---

# Per-user oRPC request rate (in-memory token bucket)
RATE_LIMIT_REQUESTS_PER_MIN=240
RATE_LIMIT_REQUESTS_PER_HOUR=4000

# Caps on concurrent background work per user
LIMIT_ACTIVE_RUNS_PER_USER=5
LIMIT_ACTIVE_JOBS_PER_USER=5

# Rolling 24-hour caps on new background work per user
LIMIT_DAILY_RUNS_PER_USER=50
LIMIT_DAILY_JOBS_PER_USER=100

# DB history cleanup (hourly cron)
HISTORY_RETENTION_DAYS=30
HISTORY_MAX_PER_USER=100

# Lockdown: comma-separated GitHub logins. Empty = open signup.
ALLOWED_GITHUB_LOGINS=

# Kill switch: when true, blocks all mutations (reads still work)
DISABLE_MUTATIONS=false
